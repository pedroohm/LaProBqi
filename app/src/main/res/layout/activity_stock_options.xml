<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".activities.StockOptionsActivity">

    <include
        android:id="@+id/headerToolbar"
        layout="@layout/header_toolbar" />

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/stock"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/red_brown"
        android:gravity="center"

        android:layout_alignTop="@id/headerToolbar"
        android:layout_alignBottom="@id/headerToolbar"
        android:layout_centerHorizontal="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/headerToolbar"
        android:layout_marginTop="40dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">



        <Button
            android:id="@+id/btnRegisterEntry"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="Registrar Novas Entradas"
            android:textColor="@color/white"
            android:backgroundTint="@color/moustard_gold"
            android:layout_marginBottom="20dp"
            android:padding="16dp"
            android:textSize="16sp"/>

        <Button
            android:id="@+id/btnRegisterExit"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="Registrar Saídas"
            android:textColor="@color/white"
            android:backgroundTint="@color/moustard_gold"
            android:padding="16dp"
            android:textSize="16sp"/>

    </LinearLayout>

</RelativeLayout>
