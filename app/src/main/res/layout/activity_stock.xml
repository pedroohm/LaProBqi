<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Cabeçalho -->
    <include
        android:id="@+id/headerToolbar"
        layout="@layout/header_toolbar" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/stock"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/red_brown"
        android:gravity="center"
        android:letterSpacing="0.1"

        android:layout_alignTop="@id/headerToolbar"
        android:layout_alignBottom="@id/headerToolbar"
        android:layout_centerHorizontal="true" />

    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerToolbar"
        android:orientation="vertical"
        android:padding="16dp">



    <!-- Campo de Pesquisa -->
    <EditText
        android:id="@+id/editPesquisa"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="🔍 Pesquisar por nome..."
        android:padding="12dp"
        android:background="@drawable/edit_text_background"
        android:layout_marginBottom="8dp"/>

    <!-- Botão Adicionar Produto -->
    <Button
        android:id="@+id/btnAdicionarProduto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+ ADICIONAR PRODUTO"
        android:textStyle="bold"
        android:backgroundTint="@color/moustard_gold"
        android:textColor="@color/white"
        android:layout_marginBottom="16dp"/>

    <!-- RecyclerView para lista de produtos em estoque -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewEstoque"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical"/>

    </LinearLayout>

</RelativeLayout>