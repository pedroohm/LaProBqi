<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="16dp">

    <!-- Cabeçalho -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/logo"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/logo" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CATÁLOGO DE PRODUTOS"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/red_brown"
            android:gravity="center"
            android:layout_marginStart="16dp"/>

        <ImageView
            android:id="@+id/btnConfig"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/config"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Campo de Pesquisa -->
    <EditText
        android:id="@+id/editPesquisa"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_below="@id/headerLayout"
        android:hint="🔍 Pesquisar por nome..."
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/input_hint"
        android:layout_marginBottom="16dp"/>

    <!-- Cabeçalho da Tabela -->
    <LinearLayout
        android:id="@+id/tableHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/editPesquisa"
        android:orientation="horizontal"
        android:background="@color/red_brown"
        android:padding="12dp"
        android:weightSum="4"
        android:layout_marginBottom="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PRODUTO"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:paddingEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CÓDIGO"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="QUANTIDADE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="VALIDADE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:paddingStart="8dp"/>

    </LinearLayout>

    <!-- RecyclerView para lista de produtos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewProdutos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tableHeader"
        android:background="@android:color/white"
        android:scrollbars="vertical"/>

</RelativeLayout>